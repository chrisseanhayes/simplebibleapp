@using simplebibleapp.xmlbible
@using Microsoft.AspNetCore.Identity
@inject SignInManager<simplebibleapp.Models.ApplicationUser> SignInManager
@model ReadViewModel
@{
    ViewBag.Title = Model.ChapterHeading;
    
    // Parse book name from ChapterHeading (e.g., "Genesis 1" -> "Genesis", "1 John 2" -> "1 John")
    var chapterHeading = Model.ChapterHeading;
    var lastSpaceIndex = chapterHeading.LastIndexOf(' ');
    var bookName = lastSpaceIndex > 0 ? chapterHeading.Substring(0, lastSpaceIndex) : chapterHeading;

    // Helper functions for deterministic minimap layout
    Func<int, int, int> getWordWidth = (verseNum, wordIndex) => {
        return 2 + ((verseNum * (wordIndex + 3)) % 6); // 2px to 7px width
    };
    Func<int, int> getWordCount = (verseNum) => {
        return 4 + (verseNum % 4); // 4 to 7 words
    };
}

<div class="read-app-container" x-data="readApp" x-init="init('@Model.BookAbbr', @Model.Chapter, '@Html.Raw(Model.ChapterHeading)', @(SignInManager.IsSignedIn(User) ? "true" : "false"))">
    <!-- Navigation Breadcrumbs -->
    <div class="bible-nav-container">
        <nav class="bible-breadcrumb" aria-label="Bible navigation breadcrumb">
            <ol class="breadcrumb-list">
                <li class="breadcrumb-item">
                    <a class="breadcrumb-button home-button" href="#" x-on:click.prevent="searchMenuVisible = true; searchView = 'books';">📖 Books</a>
                </li>
                <li class="breadcrumb-separator" aria-hidden="true">›</li>
                <li class="breadcrumb-item">
                    <a class="breadcrumb-button" href="#" x-on:click.prevent="searchMenuVisible = true; selectSearchBook('@Model.BookAbbr', '@bookName')">@bookName</a>
                </li>
                <li class="breadcrumb-separator" aria-hidden="true">›</li>
                <li class="breadcrumb-item">
                    <span class="breadcrumb-button current" style="cursor: pointer;" x-on:click="searchMenuVisible = true; selectSearchBook('@Model.BookAbbr', '@bookName').then(() => selectSearchChapter(@Model.Chapter));">Chapter @Model.Chapter</span>
                </li>
            </ol>
        </nav>
    </div>

    <!-- Chapter Heading & Navigation Controls -->
    <div class="read-controls-bar">
        <div class="chapter-header-group" style="display: flex; align-items: center; gap: 1rem;">
            @if (Model.HasPreviousChapter)
            {
                <a class="btn-chapter-nav btn-sm" 
                   href="@Url.Action("Read", new { bookAbbr = Model.PreviousChapterBookAbbr, chapter = Model.PreviousChapterNumber })"
                   title="Previous Chapter">
                    <i class="fas fa-chevron-left"></i>
                </a>
            }
            
            <h2 class="read-heading" style="margin: 0;">@Model.ChapterHeading</h2>
            
            @if (Model.HasNextChapter)
            {
                <a class="btn-chapter-nav btn-sm" 
                   href="@Url.Action("Read", new { bookAbbr = Model.NextChapterBookAbbr, chapter = Model.NextChapterNumber })"
                   title="Next Chapter">
                    <i class="fas fa-chevron-right"></i>
                </a>
            }
        </div>
        
        <div class="read-nav-actions">
            <!-- Dictionary/Strong's Sidebar Toggle -->
            <button class="btn-dict-toggle" 
                    x-bind:class="{ 'active': !fullbible }" 
                    x-on:click="fullbible = !fullbible"
                    title="Toggle Right Sidebar"
                    style="padding: 0.5rem; display: flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 6px;">
                <i class="fas" x-bind:class="fullbible ? 'fa-columns' : 'fa-times'"></i>
            </button>
        </div>
    </div>

    <!-- Text reading pane & sidebar -->
    <div id="bible-content" class="bible-read">
        <!-- Book Search Menu Sidebar -->
        <div id="bible-search-menu" class="bible-search-sidebar" x-show="searchMenuVisible" x-transition x-cloak>
            <div class="search-sidebar-header">
                <h3>
                    <template x-if="searchView === 'books'"><span>Books</span></template>
                    <template x-if="searchView !== 'books'">
                        <span>
                            <button class="btn btn-sm btn-light" x-on:click="resetSearch()" style="padding: 0 4px; border: none; background: transparent; color: var(--primary);">
                                <i class="fas fa-chevron-left"></i>
                            </button>
                            <span x-text="selectedSearchBookName"></span>
                        </span>
                    </template>
                </h3>
                <button class="btn-close-sidebar" x-on:click="searchMenuVisible = false">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="search-sidebar-content" style="flex: 1; overflow-y: auto;">
                <!-- Books View -->
                <div class="books-tight-grid" x-show="searchView === 'books'">
                    @foreach(var book in Model.Books ?? new List<simplebibleapp.xmlbiblerepository.BookListItem>())
                    {
                        var isCurrent = book.SearchAbbr == Model.BookAbbr;
                        <a href="javascript:void(0)" x-on:click="selectSearchBook('@book.SearchAbbr', '@book.BookName')" 
                           class="book-tight-btn @(isCurrent ? "active" : "") category-@book.Testament.ToLower()"
                           title="@book.BookName">
                            <span class="book-id">@(book.SearchAbbr.Length > 3 ? book.SearchAbbr.Substring(0, 3) : book.SearchAbbr)</span>
                        </a>
                    }
                </div>
                
                <!-- Loading View -->
                <div x-show="searchView === 'loading'" class="text-center p-4">
                    <i class="fas fa-spinner fa-spin fa-2x text-muted"></i>
                </div>
                
                <!-- Chapters View -->
                <div x-show="searchView === 'chapters'" class="p-2">
                    <div class="chapters-tight-grid" style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 4px;">
                        <template x-for="chap in searchChapters" :key="chap">
                            <button class="btn btn-sm"
                                    :class="selectedSearchBook === '@Model.BookAbbr' && chap === @Model.Chapter ? 'btn-primary' : 'btn-light'"
                                    x-on:click="selectSearchChapter(chap)"
                                    x-text="chap"
                                    style="width: 100%; aspect-ratio: 1; padding: 0; display: flex; align-items: center; justify-content: center; color: var(--text-primary); border: none; font-size: 0.85rem; font-weight: normal;"></button>
                        </template>
                    </div>
                </div>
                
                <!-- Verses View -->
                <div x-show="searchView === 'verses'" class="p-2">
                    <div style="margin-bottom: 8px; font-size: 0.85rem; font-weight: bold; color: var(--text-muted); cursor: pointer;" x-on:click="searchView = 'chapters'">
                        <i class="fas fa-arrow-left"></i> Chapter <span x-text="searchVerses.length ? (searchVerses[0].chapter || searchVerses[0].Chapter) : ''"></span>
                    </div>
                    <div class="verses-tight-grid" style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 4px;">
                        <template x-for="v in searchVerses" :key="v.verse || v.Verse">
                            <a :href="'/Home/Read?bookAbbr=' + encodeURIComponent(v.bookAbbreviation || v.BookAbbreviation) + '&chapter=' + (v.chapter || v.Chapter) + '#vs-' + (v.verse || v.Verse)"
                               class="btn btn-sm btn-light"
                               style="width: 100%; aspect-ratio: 1; padding: 0; display: flex; align-items: center; justify-content: center; text-decoration: none; color: var(--text-primary);"
                               x-text="v.verse || v.Verse"
                               x-on:click="searchMenuVisible = false"></a>
                        </template>
                    </div>
                </div>
            </div>
        </div>

        <div id="bible-left" class="bible-text" x-bind:style="fullbible ? 'flex: 1;' : 'flex: 1;'">
            <div class="bible-text-content">
                @Html.Partial("BibleNode", new BibleChapterReading { BibleNode = Model.BibleNode, ChapterHeading = Model.ChapterHeading, BookAbbr = Model.BookAbbr, Chapter = Model.Chapter })
            </div>
        </div>
        
        <!-- Book Minimap Sidebar -->
        <div class="bible-minimap-container">
            <div class="minimap-header">
                <span>Minimap</span>
            </div>
            <div class="minimap-chapters" id="minimap-scroll-container">
                @foreach (var chapter in Model.SelectableVerses.GroupBy(v => v.Chapter))
                {
                    var chapNum = chapter.Key;
                    var isCurrentChapter = chapNum == Model.Chapter;
                    var verses = chapter.ToArray();
                    
                    <div class="minimap-chapter @(isCurrentChapter ? "current-chapter" : "")" 
                         data-chapter="@chapNum"
                         id="minimap-ch-@chapNum">
                         
                        <a href="@Url.Action("Read", new { bookAbbr = Model.BookAbbr, chapter = chapNum })" class="minimap-chapter-link" title="Chapter @chapNum">
                            <span class="minimap-chapter-label">Ch @chapNum</span>
                        </a>
                        <div class="minimap-verses-container">
                            @foreach (var v in verses)
                            {
                                var wordCount = getWordCount(v.Verse);
                                <a href="@Url.Action("Read", new { bookAbbr = Model.BookAbbr, chapter = chapNum })#vs-@v.Verse" 
                                   class="minimap-verse" 
                                   data-chapter="@chapNum" 
                                   data-verse="@v.Verse"
                                   title="Chapter @chapNum Verse @v.Verse"
                                   x-bind:class="{ 'highlighted-verse': isVerseHighlighted(@chapNum, @v.Verse) }">
                                     @for (int i = 0; i < wordCount; i++)
                                     {
                                         var width = getWordWidth(v.Verse, i);
                                         <span class="minimap-word" style="width: @(width)px;"></span>
                                     }
                                </a>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
        
        <div id="bible-right" x-show="!fullbible" x-transition x-cloak style="display: flex; flex-direction: column;">
            <div class="search-sidebar-header">
                <h3>Dictionary</h3>
                <button class="btn-close-sidebar" x-on:click="fullbible = true">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            
            <!-- Main Sidebar Tabs (Definition, Occurrences, Usage, Synonyms, Insight) -->
            <div class="sidebar-main-tabs" style="display: flex; background: var(--bg-card); border-bottom: 1px solid var(--border-color); flex-wrap: wrap;">
                <button class="btn btn-link" :class="sidebarTab === 'definition' ? 'active font-weight-bold' : ''" x-on:click="sidebarTab = 'definition'" style="flex: 1 1 auto; padding: 8px; color: var(--text-primary); text-decoration: none;">Definition</button>
                <button class="btn btn-link" :class="sidebarTab === 'occurrences' ? 'active font-weight-bold' : ''" x-on:click="sidebarTab = 'occurrences'" style="flex: 1 1 auto; padding: 8px; color: var(--text-primary); text-decoration: none;">Occurrences</button>
                <button class="btn btn-link" :class="sidebarTab === 'usage' ? 'active font-weight-bold' : ''" x-on:click="sidebarTab = 'usage'" style="flex: 1 1 auto; padding: 8px; color: var(--text-primary); text-decoration: none;">Usage</button>
                <button class="btn btn-link" :class="sidebarTab === 'synonyms' ? 'active font-weight-bold' : ''" x-on:click="sidebarTab = 'synonyms'" style="flex: 1 1 auto; padding: 8px; color: var(--text-primary); text-decoration: none;">Synonyms</button>
                <button class="btn btn-link" :class="sidebarTab === 'insight' ? 'active font-weight-bold' : ''" x-on:click="sidebarTab = 'insight'" style="flex: 1 1 auto; padding: 8px; color: var(--text-primary); text-decoration: none;">Insight</button>
                <button class="btn btn-link" :class="sidebarTab === 'notes' ? 'active font-weight-bold' : ''" x-on:click="sidebarTab = 'notes'; loadChapterNotes();" style="flex: 1 1 auto; padding: 8px; color: var(--text-primary); text-decoration: none;" id="notes-tab-btn">
                    <i class="fas fa-sticky-note" style="margin-right:3px;"></i>Notes
                    <span class="notes-count-badge" x-show="chapterNotesCount > 0" x-text="chapterNotesCount" style="font-size:0.7rem; background:var(--primary); color:#fff; border-radius:999px; padding:1px 5px; margin-left:2px;"></span>
                </button>
            </div>

            <div class="bible-right-content" style="flex: 1; overflow-y: auto; display: flex; flex-direction: column;">
                
                <!-- Definition Tab -->
                <div x-show="sidebarTab === 'definition'" style="display: flex; flex-direction: column; height: 100%;">
                    <!-- Multi-Lemma Definition Tabs -->
                    <div class="def-tabs-header" x-show="htmlItems.length > 1" style="display: flex; gap: 4px; padding: 8px; background: var(--bg-card-hover); border-bottom: 1px solid var(--border-color); overflow-x: auto;">
                        <template x-for="item in htmlItems" :key="item.ref">
                            <button class="btn btn-sm"
                                    :class="defActiveTab === item.ref ? 'btn-primary' : 'btn-light'"
                                    x-on:click="defActiveTab = item.ref; loadRef(item.ref, true);"
                                    x-text="item.ref"
                                    style="border-radius: 12px; padding: 2px 10px; font-size: 0.8rem;"></button>
                        </template>
                    </div>
                    
                    <div class="def-tab-content bible-def-sticky" style="flex: 1; overflow-y: auto; padding: 10px;">
                        <template x-for="item in htmlItems" :key="item.ref">
                            <div x-show="defActiveTab === item.ref" x-html="item.html"></div>
                        </template>
                        
                        <div x-show="defload" class="text-center py-4">
                            <i class="fas fa-spinner fa-spin fa-2x text-primary"></i>
                        </div>
                    </div>
                </div>

                <!-- Occurrences Tab -->
                <div x-show="sidebarTab === 'occurrences'" style="padding: 10px;">
                    <div class="word-usage-excluded alert alert-info my-3" x-show="isExcluded">
                        <i class="fas fa-info-circle mr-1"></i>
                        Common conjunctions, prepositions, and articles are currently excluded from search to optimize performance.
                    </div>
                    
                    <div class="word-usage-container" x-show="!isExcluded && bookOccurrences.length > 0">
                        <h4 class="usage-title">Book Occurrences:</h4>
                        <div class="d-flex flex-wrap" style="gap: 4px; margin-top: 12px;">
                            <template x-for="occ in bookOccurrences" x-bind:key="occ.bookAbbr">
                                <button class="btn btn-xs"
                                        :class="selectedUsageBook === occ.bookAbbr ? 'btn-primary' : 'btn-light'"
                                        x-on:click="selectUsageBook(occ.bookAbbr); sidebarTab = 'usage';"
                                        style="padding: 4px 8px; font-size: 0.85rem; border-radius: 4px; display: inline-flex; align-items: center; gap: 4px;">
                                    <span x-text="occ.bookAbbr"></span>
                                    <span class="badge" :class="selectedUsageBook === occ.bookAbbr ? 'badge-light text-primary' : 'badge-secondary'" x-text="occ.count"></span>
                                </button>
                            </template>
                        </div>
                    </div>
                </div>

                <!-- Usage Tab -->
                <div x-show="sidebarTab === 'usage'" style="padding: 10px;">
                    <div class="word-usage-container" x-show="!isExcluded && wordRefs.length > 0">
                        <div class="text-muted small font-weight-bold mb-2">
                            Showing occurrences in <span x-text="selectedUsageBook"></span>:
                        </div>

                        <template x-for="verse in wordRefs" x-bind:key="verse.chapterAbbr + '.' + verse.chapterNumber + '.' + verse.verseNumber">
                            <a :href="`/Home/Read?bookAbbr=${encodeURIComponent(verse.chapterAbbr)}&chapter=${verse.chapterNumber}#vs-${verse.verseNumber}`"
                               class="usage-ref"
                               x-on:click="if (verse.chapterAbbr.toLowerCase() === bookAbbr.toLowerCase() && verse.chapterNumber === chapter) { $event.preventDefault(); window.location.hash = 'vs-' + verse.verseNumber; }">
                                <span x-text="verse.chapterAbbr"></span>
                                <span x-text="verse.chapterNumber"></span>:<span x-text="verse.verseNumber"></span>
                                &quot;<span x-html="decode(verse.verseXmlText)"></span>&quot;
                            </a>
                        </template>
                    </div>
                </div>

                <!-- Synonyms Tab -->
                <div x-show="sidebarTab === 'synonyms'" style="padding: 10px;">
                    <div class="syn-panel" style="display: block; position: static; box-shadow: none; border: none; height: auto;">
                        <div class="syn-panel-header" x-show="synonymData">
                            <div class="syn-panel-title">
                                <i class="fas fa-project-diagram"></i>
                                Semantic Network
                                <span class="syn-ref-badge" x-text="synonymActiveRef"></span>
                            </div>
                        </div>

                        <div class="syn-loading" x-show="synonymLoading">
                            <i class="fas fa-spinner fa-spin"></i>
                            <span>Analysing with Gemini&hellip;</span>
                        </div>

                        <div class="syn-error" x-show="!synonymLoading && synonymError" x-text="synonymError"></div>

                        <div class="text-center py-4" x-show="!synonymLoading && !synonymData && activeRef">
                            <button class="btn btn-primary btn-sm" x-on:click="
                                const lang = activeRef.startsWith('H') ? 'Hebrew' : 'Greek';
                                loadSynonyms(activeRef, '@Model.ChapterHeading', '', lang);
                            ">
                                <i class="fas fa-project-diagram"></i> Generate Semantic Network
                            </button>
                        </div>

                        <div x-show="!synonymLoading && synonymData">
                            <div class="syn-card" x-show="synonymData?.target_selection">
                                <div class="syn-lemma" x-text="synonymData?.target_selection?.anchor_lemma"></div>
                                <div class="syn-translit" x-text="synonymData?.target_selection?.transliteration"></div>
                                <div class="syn-gloss" x-text="'\u201c' + (synonymData?.target_selection?.contextual_gloss || '') + '\u201d'"></div>
                            </div>

                            <div class="syn-section" x-show="synonymData?.exegetical_context">
                                <div class="syn-section-label">Exegetical Context</div>
                                <div class="syn-context-row">
                                    <span class="syn-context-key">Role:</span>
                                    <span x-text="synonymData?.exegetical_context?.immediate_context_role"></span>
                                </div>
                                <div class="syn-context-row">
                                    <span class="syn-context-key">Function:</span>
                                    <span x-text="synonymData?.exegetical_context?.local_thematic_function"></span>
                                </div>
                                <div class="syn-context-row">
                                    <span class="syn-context-key">Canon:</span>
                                    <span x-text="synonymData?.exegetical_context?.canonical_trajectory_summary"></span>
                                </div>
                            </div>

                            <div class="syn-section" x-show="synonymData?.synonym_network?.length > 0">
                                <div class="syn-section-label">Synonym Network</div>
                                <div class="syn-network-grid">
                                    <template x-for="(node, i) in (synonymData?.synonym_network || [])" :key="node.strongs + i">
                                        <div class="syn-node"
                                             x-bind:class="'rel-' + node.relationship"
                                             x-on:click="loadRef(node.strongs)">
                                            <div class="syn-node-top">
                                                <span class="syn-node-lemma" x-text="node.lemma"></span>
                                                <span class="syn-node-strongs" x-text="node.strongs"></span>
                                            </div>
                                            <div class="syn-node-translit" x-text="node.transliteration"></div>
                                            <div class="syn-node-gloss" x-text="node.primary_gloss"></div>
                                            <div class="syn-node-meta">
                                                <span class="syn-rel-badge" x-text="relationshipLabel(node.relationship)"></span>
                                                <span class="syn-conf-badge" x-bind:class="confidenceClass(node.contextual_confidence)" x-text="Math.round(node.contextual_confidence * 100) + '%'"></span>
                                            </div>
                                            <div class="syn-node-notes" x-show="node.thematic_alignment_notes" x-text="node.thematic_alignment_notes"></div>
                                        </div>
                                    </template>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Verse Insight Tab -->
                <div x-show="sidebarTab === 'insight'" style="padding: 10px;">
                    <div class="syn-panel" style="display: block; position: static; box-shadow: none; border: none; height: auto;">
                        <div class="syn-panel-header" x-show="insightActiveRef">
                            <div class="syn-panel-title">
                                <i class="fas fa-book-reader"></i>
                                Verse Synopsis
                                <span class="syn-ref-badge" x-text="insightActiveRef"></span>
                            </div>
                        </div>

                        <div class="syn-loading" x-show="insightLoading">
                            <i class="fas fa-spinner fa-spin"></i>
                            <span>Analysing with AGY CLI...</span>
                        </div>

                        <div class="syn-error" x-show="!insightLoading && insightError" x-text="insightError"></div>

                        <div class="text-center py-4" x-show="!insightLoading && !insightData && !insightActiveRef">
                            <p class="text-muted">Click a verse number in the text to load its synopsis.</p>
                        </div>

                        <div x-show="!insightLoading && insightData">
                            <div class="insight-content" x-html="insightData?.renderedHtml"></div>
                        </div>
                    </div>
                </div>

                <!-- Notes Tab -->
                <div x-show="sidebarTab === 'notes'" style="padding: 10px; display: flex; flex-direction: column; gap: 12px;">

                    <!-- Not logged in -->
                    <div x-show="!isAuthenticated" class="notes-auth-prompt">
                        <i class="fas fa-lock" style="font-size:1.5rem; color:var(--text-muted); margin-bottom:8px;"></i>
                        <p style="color:var(--text-muted); font-size:0.9rem; margin:0 0 10px;">Sign in to save personal study notes.</p>
                        <a href="/Account/Login" class="btn btn-primary btn-sm">Sign In</a>
                    </div>

                    <!-- Logged in -->
                    <div x-show="isAuthenticated">

                        <!-- ── Active verse editor ── -->
                        <div x-show="noteEditorVerse !== null" class="note-editor-card" id="note-editor-panel">
                            <div class="note-editor-header">
                                <span>
                                    <i class="fas fa-pen-nib"></i>
                                    <span x-text="'@Model.ChapterHeading:' + noteEditorVerse"></span>
                                </span>
                                <button class="btn-close-note" x-on:click="closeNoteEditor()" title="Close editor">
                                    <i class="fas fa-times"></i>
                                </button>
                            </div>

                            <!-- Personal note textarea -->
                            <div class="note-section-label">
                                <i class="fas fa-pencil-alt"></i> Personal Note
                            </div>
                            <textarea id="note-textarea"
                                      class="note-textarea"
                                      x-model="noteEditorText"
                                      placeholder="Write your own study notes here…"
                                      rows="4"
                                      x-on:keydown.ctrl.enter.prevent="saveNote()"
                                      x-on:keydown.meta.enter.prevent="saveNote()"></textarea>
                            <div class="note-editor-actions">
                                <button class="btn btn-primary btn-sm" x-on:click="saveNote()" :disabled="noteSaving">
                                    <i class="fas" :class="noteSaving ? 'fa-spinner fa-spin' : 'fa-save'"></i>
                                    <span x-text="noteSaving ? 'Saving…' : 'Save'"></span>
                                </button>
                                <button class="btn btn-sm btn-light" x-on:click="closeNoteEditor()" :disabled="noteSaving">Cancel</button>
                                <button class="btn btn-sm btn-danger"
                                        x-show="noteEditorVerse !== null && chapterNotes[noteEditorVerse]?.personal"
                                        x-on:click="deleteNote()" :disabled="noteSaving" style="margin-left:auto;">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                            <div x-show="noteSaveError" class="note-save-error" x-text="noteSaveError"></div>

                            <!-- ── AI Ask box ── -->
                            <div class="note-ai-divider">
                                <i class="fas fa-robot"></i> Ask AI about this verse
                            </div>
                            <div class="note-ai-input-row">
                                <input id="ai-question-input"
                                       class="note-ai-input"
                                       type="text"
                                       x-model="aiQuestion"
                                       placeholder="e.g. Why did they use rocks?"
                                       x-on:keydown.enter.prevent="askAi()"
                                       :disabled="aiLoading" />
                                <button class="btn btn-sm note-ai-btn"
                                        x-on:click="askAi()"
                                        :disabled="aiLoading || !aiQuestion.trim()"
                                        title="Ask AI">
                                    <i class="fas" :class="aiLoading ? 'fa-spinner fa-spin' : 'fa-paper-plane'"></i>
                                </button>
                            </div>
                            <div x-show="aiLoading" class="note-ai-status">
                                <i class="fas fa-spinner fa-spin"></i> AGY is thinking…
                            </div>
                            <div x-show="aiError && !aiLoading" class="note-save-error" x-text="aiError"></div>
                        </div>

                        <!-- ── Chapter notes list ── -->
                        <div class="notes-chapter-list">
                            <div class="notes-list-header">
                                <span>Notes in this chapter</span>
                                <span class="notes-list-count" x-text="chapterNotesCount + ' verse' + (chapterNotesCount === 1 ? '' : 's')"></span>
                            </div>

                            <div x-show="notesLoading" class="text-center py-3">
                                <i class="fas fa-spinner fa-spin text-muted"></i>
                            </div>

                            <div x-show="!notesLoading && chapterNotesCount === 0" class="notes-empty-state">
                                <i class="fas fa-feather-alt"></i>
                                <p>No notes yet for this chapter.</p>
                                <p style="font-size:0.8rem; color:var(--text-muted);">Click any verse number in the text to start.</p>
                            </div>

                            <!-- Per-verse note groups -->
                            <template x-for="(entry, verse) in chapterNotes" :key="verse">
                                <div x-show="entry.personal || entry.aiNotes.length > 0" class="note-verse-group">

                                    <!-- Verse header row -->
                                    <div class="note-verse-group-header" x-on:click="openNoteEditorForVerse(parseInt(verse))">
                                        <span class="note-list-verse-pill" x-text="'v.' + verse"></span>
                                        <span class="note-verse-group-counts">
                                            <span x-show="entry.personal" title="Personal note"><i class="fas fa-pencil-alt"></i></span>
                                            <span x-show="entry.aiNotes.length > 0" x-text="entry.aiNotes.length + ' AI'" title="AI notes" class="note-ai-count-badge"></span>
                                        </span>
                                    </div>

                                    <!-- Personal note preview -->
                                    <div x-show="entry.personal" class="note-list-item note-personal-item"
                                         x-on:click="openNoteEditorForVerse(parseInt(verse))">
                                        <div class="note-list-text" x-text="entry.personal?.text"></div>
                                        <div class="note-list-meta" x-text="formatNoteDate(entry.personal?.updatedAt)"></div>
                                    </div>

                                    <!-- AI notes -->
                                    <template x-for="(ain, idx) in entry.aiNotes" :key="ain.id">
                                        <div class="note-list-item note-ai-item">
                                            <div class="note-ai-prompt-label">
                                                <i class="fas fa-robot"></i>
                                                <span x-text="ain.prompt"></span>
                                            </div>
                                            <div class="note-list-text" x-show="!ain.renderedHtml" x-text="ain.text"></div>
                                            <div class="note-ai-rendered" x-show="ain.renderedHtml" x-html="ain.renderedHtml"></div>
                                            <div class="note-ai-item-footer">
                                                <span class="note-list-meta" x-text="formatNoteDate(ain.updatedAt)"></span>
                                                <button class="note-ai-delete-btn"
                                                        x-on:click.stop="deleteAiNote(parseInt(verse), ain.id)"
                                                        title="Delete this AI note">
                                                    <i class="fas fa-times"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </template>
                                </div>
                            </template>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
